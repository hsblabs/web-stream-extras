{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": false,
		"noEmit": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"strictFunctionTypes": true,
		"skipLibCheck": true,
		"lib": ["ESNext"],
		"types": ["node"]
	},
	"include": ["./**/*.ts"]
}
