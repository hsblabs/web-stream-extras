{
	"name": "@hsblabs/web-stream-extras",
	"version": "0.5.0",
	"description": "Utilities for WHATWG streams.",
	"type": "module",
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"bench": "pnpm build && node --experimental-strip-types ./bench/encryption.bench.ts",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"typecheck": "tsc -p tsconfig.typecheck.json",
		"publish:check": "biome check . && pnpm typecheck && pnpm test && pnpm build",
		"prepublishOnly": "pnpm publish:check",
		"test": "vitest run ./src",
		"test:watch": "vitest ./src",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format --write ."
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": "./dist/index.js",
		"./base64": "./dist/base64.js",
		"./cobs": "./dist/cobs.js",
		"./encryption": "./dist/encryption.js",
		"./jsonl": "./dist/jsonl.js",
		"./png": "./dist/png.js",
		"./text": "./dist/text.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"keywords": [
		"web-stream",
		"whatwg-stream",
		"stream",
		"encryption",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hsblabs/web-stream-extras"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@changesets/cli": "^2.31.0",
		"@types/node": "catalog:",
		"tsdown": "^0.21.10",
		"typescript": "6.0.0-beta",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.33.2"
}
