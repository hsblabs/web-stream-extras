{
  "name": "@hsblabs/web-stream-extras",
  "version": "0.2.0",
  "description": "Utilities for WHATWG streams.",
  "type": "module",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "bench": "pnpm build && node --experimental-strip-types ./bench/encryption.bench.ts",
    "test:package": "pnpm build && node ./scripts/package-smoke.mjs",
    "publish:check": "pnpm lint && pnpm test && pnpm test:package",
    "prepublishOnly": "pnpm publish:check",
    "test": "vitest run ./src",
    "test:watch": "vitest ./src",
    "lint": "biome check ./src ./bench ./scripts",
    "lint:fix": "biome check ./src ./bench ./scripts --write",
    "format": "biome format --write ./src ./bench ./scripts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./cobs": "./dist/cobs.js",
    "./encryption": "./dist/encryption.js",
    "./png": "./dist/png.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "web-stream",
    "whatwg-stream",
    "stream",
    "encryption",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hsblabs/web-stream-extras"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/node": "^25.3.3",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "6.0.0-beta",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3"
}
